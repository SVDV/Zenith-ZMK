#include <dt-bindings/zmk/matrix_transform.h>
#include "zenith_layouts.dtsi"

&ergomech_zenith_layout {
    transform = <&default_transform>;
};

/*
 * Extend the upstream xiao_d connector with the XIAO BLE's bottom SMD
 * pads (D11-D19). The upstream Zephyr connector only exposes D0-D10.
 * Zenith's kscan wires columns to pads D17-D19 for the outer-pinky
 * column, so the matrix won't scan without this override.
 */
&xiao_d {
    gpio-map
        = <0 0 &gpio0 2 0>
        , <1 0 &gpio0 3 0>
        , <2 0 &gpio0 28 0>
        , <3 0 &gpio0 29 0>
        , <4 0 &gpio0 4 0>
        , <5 0 &gpio0 5 0>
        , <6 0 &gpio1 11 0>
        , <7 0 &gpio1 12 0>
        , <8 0 &gpio1 13 0>
        , <9 0 &gpio1 14 0>
        , <10 0 &gpio1 15 0>
        , <11 0 &gpio0 15 0>
        , <12 0 &gpio0 19 0>
        , <13 0 &gpio1 1 0>
        , <14 0 &gpio0 9 0>
        , <15 0 &gpio0 10 0>
        , <16 0 &gpio0 31 0>
        , <17 0 &gpio1 7 0>
        , <18 0 &gpio1 5 0>
        , <19 0 &gpio1 3 0>
        ;
};

/ {
    chosen {
        zmk,kscan = &kscan0;        
        //zmk,matrix_transform = &default_transform;
        zmk,physical-layout = &ergomech_zenith_layout;
};

    default_transform: keymap_transform_0 {
        compatible = "zmk,matrix-transform";
        columns = <12>;
        rows = <4>;
//             | SW01  | SW02  | SW03  | SW04  | SW05  |  | SW05  | SW04  | SW03  | SW02  | SW01  |
//             | SW06  | SW07  | SW08  | SW09  | SW10  |  | SW10  | SW09  | SW08  | SW07  | SW06  | 
//      | SW16 | SW11  | SW12  | SW13  | SW14  | SW15  |  | SW15  | SW14  | SW13  | SW12  | SW11  | SW16  |
//                             | SW17  | SW18  | SW19  |  | SW19  | SW18  | SW17  | 
        map = <
        RC(0,0) RC(0,1) RC(0,2) RC(0,3) RC(0,4) RC(0,5)     RC(0,6) RC(0,7) RC(0,8) RC(0,9) RC(0,10) RC(0,11)
        RC(1,0) RC(1,1) RC(1,2) RC(1,3) RC(1,4) RC(1,5)     RC(1,6) RC(1,7) RC(1,8) RC(1,9) RC(1,10) RC(1,11)
        RC(2,0) RC(2,1) RC(2,2) RC(2,3) RC(2,4) RC(2,5)     RC(2,6) RC(2,7) RC(2,8) RC(2,9) RC(2,10) RC(2,11)
                                RC(3,3) RC(3,4) RC(3,5)     RC(3,6) RC(3,7) RC(3,8)         
        >;
    };


    kscan0: kscan_0 {
        compatible = "zmk,kscan-gpio-matrix";
        label = "KSCAN";
        wakeup-source;

        diode-direction = "col2row";
        row-gpios
            = <&xiao_d 0 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>
            , <&xiao_d 1 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>
            , <&xiao_d 2 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>
            , <&xiao_d 3 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>
            ;
    };
};
